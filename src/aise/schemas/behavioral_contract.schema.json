{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "behavioral_contract",
  "title": "Behavioral contract (architect output, phase 2)",
  "description": "Black-box observable scenarios. Drives verification phase fanout. Each scenario is implementable as a single test with trigger + effect + preconditions.",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/scenario" }
    }
  },
  "additionalProperties": true,

  "definitions": {
    "scenario": {
      "type": "object",
      "required": ["id", "name", "trigger", "effect"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "preconditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trigger": {
          "type": "object",
          "minProperties": 1
        },
        "effect": {
          "type": "object",
          "minProperties": 1
        },
        "covers_requirements": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(FR|NFR)-\\d{2,4}$" }
        }
      },
      "additionalProperties": true
    }
  }
}
